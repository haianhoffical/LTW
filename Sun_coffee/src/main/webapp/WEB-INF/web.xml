<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="5.0">
    <display-name>Sun Coffee Management</display-name>
    <welcome-file-list><welcome-file>login.jsp</welcome-file></welcome-file-list>
    <!-- [A1] Filter kiểm tra đăng nhập -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.cafe.filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping><filter-name>AuthenticationFilter</filter-name><url-pattern>/admin/*</url-pattern></filter-mapping>
    <filter-mapping><filter-name>AuthenticationFilter</filter-name><url-pattern>/staff/*</url-pattern></filter-mapping>
    <!-- [A1] LoginServlet -->
    <servlet><servlet-name>LoginServlet</servlet-name><servlet-class>com.cafe.controller.LoginServlet</servlet-class></servlet>
    <servlet-mapping><servlet-name>LoginServlet</servlet-name><url-pattern>/LoginServlet</url-pattern></servlet-mapping>
    <!-- [A1] LogoutServlet -->
    <servlet><servlet-name>LogoutServlet</servlet-name><servlet-class>com.cafe.controller.LogoutServlet</servlet-class></servlet>
    <servlet-mapping><servlet-name>LogoutServlet</servlet-name><url-pattern>/LogoutServlet</url-pattern></servlet-mapping>
    <!-- [A1] OrderServlet -->
    <servlet><servlet-name>OrderServlet</servlet-name><servlet-class>com.cafe.controller.OrderServlet</servlet-class></servlet>
    <servlet-mapping><servlet-name>OrderServlet</servlet-name><url-pattern>/OrderServlet</url-pattern></servlet-mapping>
    <!-- [B1] ProductServlet -->
    <servlet><servlet-name>ProductServlet</servlet-name><servlet-class>com.cafe.controller.ProductServlet</servlet-class></servlet>
    <servlet-mapping><servlet-name>ProductServlet</servlet-name><url-pattern>/ProductServlet</url-pattern></servlet-mapping>
    <!-- [B1] CategoryServlet -->
    <servlet><servlet-name>CategoryServlet</servlet-name><servlet-class>com.cafe.controller.CategoryServlet</servlet-class></servlet>
    <servlet-mapping><servlet-name>CategoryServlet</servlet-name><url-pattern>/CategoryServlet</url-pattern></servlet-mapping>
    <!-- [B1] StatisticServlet -->
    <servlet><servlet-name>StatisticServlet</servlet-name><servlet-class>com.cafe.controller.StatisticServlet</servlet-class></servlet>
    <servlet-mapping><servlet-name>StatisticServlet</servlet-name><url-pattern>/StatisticServlet</url-pattern></servlet-mapping>
    <request-character-encoding>UTF-8</request-character-encoding>
    <error-page><error-code>404</error-code><location>/login.jsp</location></error-page>
</web-app>
